<!DOCTYPE html>
<html>
<head>
    <title>Bootstrap Online Editor</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>

    <div class="container">
        <form action="#" area-controller="" area-action="">
            <h2>Problemas</h2>
            <div class="container">
                <div class="col-5">
                    <select class="form-select">
                        <option default></option>
                        <option>Caida de server</option>
                        <option>Fallo de base de datos</option>
                        <option>Nomina incorrecta</option>
                        <option>Fallo de sistema</option>
                        <option>Software desactualizado</option>
                    </select>
                </div>
            </div>

            <p>Coloque sus comentatios al respecto al problema que presenta:</p>
            <div class="mb-3 mt-3">
                <label for="comment">Detalles:</label>
                <textarea class="form-control" rows="5" id="comment" name="text"></textarea>
            </div>
        </form>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#myModal">Enviar</button>
    </div>


    <div id="myModal" class="container modal">
        <form area-controller="" area-action="">
            <div class="modal-dialog mb-3 mt-3">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2>Inicie sesion</h2>
                    </div>
                    <div class="container">
                        <div class="mb-3 mt-3">
                            <label for="email" class="form-label">Correo:</label>
                            <input type="email" class="form-control" id="email" placeholder="Introduzca correo" name="email">

                            <label for="pwd" class="form-label">Contraseńa:</label>
                            <input type="password" class="form-control" id="pwd" placeholder="Introduzca contraseńa" name="pswd">
                        </div>
                        <div class="form-check mb-3">
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" name="remember"> Recordarme
                            </label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Ingresar</button>
                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
    </div>

</body>
</html>