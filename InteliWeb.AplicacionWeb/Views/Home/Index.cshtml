@{
    ViewData["Title"] = "Home Page";
}

<div class="container d-block div-ttl">
    <h1>¡Servicios que ofrecemos!</h1>
</div>

<div id="demo" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#demo" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#demo" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#demo" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/img/develop.jpg" class="slide" alt="Desarrollos" style="width:100%">
            <div class="carousel-caption img-container">
                <h3>Desarrollo de software</h3>
                <p>Desarrollando los mejores productos para todas las situaciones</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/img/servers.png" class="slide" alt="Servidores" style="width:100%">
            <div class="carousel-caption img-container">
                <h3>Instalación de servidores</h3>
                <p>Implementando la mejor infraestructura para la seguridad de su información</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/img/software.jpg" class="slide" alt="Capacitaciones" style="width:100%">
            <div class="carousel-caption img-container">
                <h3>Capacitación de software</h3>
                <p>Compartiendo una amplia gama de conocimeintos en los softwares de contabilidad mas demandantes del mercado!</p>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#demo" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#demo" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>


